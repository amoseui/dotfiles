{
  "model": "claude-opus-4-8",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "KNOWLEDGE_GRAPH_PATH=\"$HOME/Obsidian/amoseui/5. Claude/knowledge\" python3 \"$HOME/.claude/hooks/knowledge-graph-update.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "KNOWLEDGE_GRAPH_PATH=\"$HOME/Obsidian/amoseui/5. Claude/knowledge\" bash \"$HOME/.claude/hooks/knowledge-graph-inject.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "codex@openai-codex": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "Korean",
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
